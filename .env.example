# Remote Ollama server
OLLAMA_BASE_URL=http://192.168.1.20:11434
OLLAMA_MODEL=gpt-oss:20b

# Official Slack MCP server. Complete Slack OAuth and place the user token here.
SLACK_MCP_URL=https://mcp.slack.com/mcp
SLACK_MCP_TOKEN=xoxp-your-user-token

# Writes are blocked unless `--allow-writes` is passed.
SLACK_ALLOW_WRITES_BY_DEFAULT=false
MAX_TOOL_STEPS=8
